# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database (SQLAlchemy async engine) ───────────────────────────────────────
# Use postgresql+asyncpg:// scheme for SQLAlchemy
DATABASE_URL=postgresql+asyncpg://agent:secret@localhost:5432/agentdb

# ── Database (LangGraph AsyncPostgresSaver) ───────────────────────────────────
# Use plain postgresql:// scheme — LangGraph manages its own pool
CHECKPOINT_DATABASE_URL=postgresql://agent:secret@localhost:5432/agentdb

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── Response cache ────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=300

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# ── LangSmith (optional tracing) ─────────────────────────────────────────────
# LANGSMITH_PROJECT=agent-api
